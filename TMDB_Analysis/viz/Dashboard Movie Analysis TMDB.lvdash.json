{
  "datasets": [
    {
      "name": "c2e531ab",
      "displayName": "Total Movies",
      "queryLines": [
        "--Total Movies\r\n",
        "SELECT COUNT(DISTINCT movie_key) AS total_movies\r\n",
        "FROM analisis_tmdb.gold.fact_movies;"
      ]
    },
    {
      "name": "2eb3e282",
      "displayName": "Total votes",
      "queryLines": [
        "-- Total votes\r\n",
        "WITH movies AS (\r\n",
        "    SELECT\r\n",
        "        movie_key,\r\n",
        "        MAX(vote_count) AS vote_count\r\n",
        "    FROM analisis_tmdb.gold.fact_movies\r\n",
        "    GROUP BY movie_key\r\n",
        ")\r\n",
        "SELECT SUM(vote_count) AS total_votes\r\n",
        "FROM movies;"
      ]
    },
    {
      "name": "060688c6",
      "displayName": "Top Rated Movie",
      "queryLines": [
        "--Top Rated Movie\r\n",
        "WITH movies AS (\r\n",
        "    SELECT\r\n",
        "        f.movie_key,\r\n",
        "        MAX(f.vote_average) AS vote_average,\r\n",
        "        MAX(f.vote_count) AS vote_count\r\n",
        "    FROM analisis_tmdb.gold.fact_movies f\r\n",
        "    GROUP BY f.movie_key\r\n",
        ")\r\n",
        "\r\n",
        "SELECT\r\n",
        "    m.title,\r\n",
        "    vote_average,\r\n",
        "    vote_count\r\n",
        "FROM movies mv\r\n",
        "JOIN analisis_tmdb.gold.dim_movies m\r\n",
        "    ON mv.movie_key = m.movie_key\r\n",
        "WHERE vote_count >= 1000\r\n",
        "ORDER BY vote_average DESC\r\n",
        "LIMIT 1;"
      ]
    },
    {
      "name": "5a69722c",
      "displayName": "Genre Distribution",
      "queryLines": [
        "--Genre Distribution\r\n",
        "SELECT g.genre_name,\r\n",
        "       COUNT(*) AS total_movies\r\n",
        "FROM analisis_tmdb.gold.fact_movies f\r\n",
        "JOIN analisis_tmdb.gold.dim_genres g\r\n",
        "  ON f.genre_key = g.genre_key\r\n",
        "GROUP BY g.genre_name\r\n",
        "ORDER BY total_movies DESC;"
      ]
    },
    {
      "name": "7055e193",
      "displayName": "Average Movie Rating by Genre (Weighted)",
      "queryLines": [
        "WITH movies AS (\r\n",
        "    SELECT\r\n",
        "        f.movie_key,\r\n",
        "        f.genre_key,\r\n",
        "        MAX(f.vote_average) AS vote_average,\r\n",
        "        MAX(f.vote_count) AS vote_count\r\n",
        "    FROM analisis_tmdb.gold.fact_movies f\r\n",
        "    GROUP BY f.movie_key, f.genre_key\r\n",
        ")\r\n",
        "\r\n",
        "SELECT\r\n",
        "    g.genre_name,\r\n",
        "    ROUND(SUM(vote_average * vote_count) / SUM(vote_count),2) AS weighted_rating\r\n",
        "FROM movies m\r\n",
        "JOIN analisis_tmdb.gold.dim_genres g\r\n",
        "  ON m.genre_key = g.genre_key\r\n",
        "GROUP BY g.genre_name\r\n",
        "ORDER BY weighted_rating DESC;"
      ]
    },
    {
      "name": "7bd3ff22",
      "displayName": "Popularity vs Rating",
      "queryLines": [
        "WITH movies AS (\r\n",
        "    SELECT\r\n",
        "        m.title,\r\n",
        "        MAX(vote_average) AS vote_average,\r\n",
        "        MAX(popularity) AS popularity,\r\n",
        "        MAX(vote_count) AS vote_count\r\n",
        "    FROM analisis_tmdb.gold.fact_movies f\r\n",
        "    JOIN analisis_tmdb.gold.dim_movies m \r\n",
        "    ON f.movie_key = m.movie_key \r\n",
        "    GROUP BY m.title\r\n",
        ")\r\n",
        "SELECT *, CASE\r\n",
        "        WHEN vote_average >= 7.5 AND popularity <= 10 THEN 'Hidden Gems'\r\n",
        "        ELSE 'Other'\r\n",
        "    END AS category\r\n",
        "FROM movies\r\n",
        "WHERE vote_count >= 1000\r\n",
        "--AND vote_average >= 7.5\r\n",
        "--AND popularity <= 10\r\n",
        "\r\n",
        ";"
      ]
    },
    {
      "name": "cc9fa06b",
      "displayName": "Movies by year",
      "queryLines": [
        "SELECT\r\n",
        "    release_year,\r\n",
        "    COUNT(*) AS total_movies\r\n",
        "FROM analisis_tmdb.gold.dim_movies\r\n",
        "GROUP BY release_year\r\n",
        "ORDER BY release_year;"
      ]
    }
  ],
